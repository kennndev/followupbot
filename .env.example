# =============================================================================
# FollowUp Bot — Environment Variables
# Copy this to .env.local and fill in your actual keys
# =============================================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- OpenAI (Whisper for voice transcription) ---
OPENAI_API_KEY=sk-...

# --- Anthropic (Claude Haiku for extraction + conversation brain) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Twilio (voice calls to patients) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Base URL where Twilio can reach your webhooks (use ngrok for local dev)
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com

# --- WhatsApp Business API ---
# Option A: Meta direct (cheaper, slower setup)
WHATSAPP_ACCESS_TOKEN=your_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=pick_any_string_for_webhook_verification

# Option B: Wati/Interakt reseller (faster setup) — set these instead
# WATI_API_KEY=
# WATI_BASE_URL=

# --- Google Calendar (for rebooking) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=   # obtained via OAuth flow once per doctor

# --- Cron secret (protects /api/cron/* endpoints) ---
CRON_SECRET=pick_a_random_long_string

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
